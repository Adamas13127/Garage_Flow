# Ce fichier montre les variables necessaires pour configurer le backend GarageFlow.
# Il existe pour aider chaque developpeur a creer son propre fichier .env local.
# Il ne doit contenir aucun secret reel, seulement des exemples de configuration.
APP_ENV=dev
APP_SECRET=
DEFAULT_URI=http://localhost
DATABASE_URL="mysql://user:password@127.0.0.1:3306/garageflow?serverVersion=8.0"
JWT_SECRET=
# Pour Mailtrap, copier cette valeur dans .env.local et remplacer USERNAME/PASSWORD par les identifiants du bac a sable.
MAILER_DSN=smtp://USERNAME:PASSWORD@sandbox.smtp.mailtrap.io:2525
JWT_SECRET_KEY=
JWT_PUBLIC_KEY=
JWT_PASSPHRASE=
JWT_TOKEN_TTL=