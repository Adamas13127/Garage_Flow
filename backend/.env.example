# Ce fichier montre les variables necessaires pour configurer le backend GarageFlow.
# Il existe pour aider chaque developpeur a creer son propre fichier .env local.
# Il ne doit contenir aucun secret reel.
APP_ENV=dev
APP_SECRET=
DEFAULT_URI=http://localhost
DATABASE_URL="mysql://user:password@127.0.0.1:3306/garageflow?serverVersion=8.0"
JWT_SECRET=
MAILER_DSN=