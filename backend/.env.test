# Ce fichier configure l'environnement de test du backend GarageFlow.
# Il existe pour isoler les tests automatises de la base de developpement.
# Il communique avec Symfony, Doctrine et PHPUnit sans stocker de secret reel.
KERNEL_CLASS='App\Kernel'
APP_SECRET='test-secret-not-used-in-production'
DATABASE_URL="mysql://garageflow:garageflow@127.0.0.1:3306/garageflow?serverVersion=8.0&charset=utf8mb4"
MAILER_DSN=null://null