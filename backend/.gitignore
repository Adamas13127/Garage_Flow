# Ce fichier indique les elements techniques du backend Symfony a ne pas versionner.
# Il existe pour eviter d'ajouter les dependances, caches et secrets locaux dans Git.

###> symfony/framework-bundle ###
/.env.local
/.env.local.php
/.env.*.local
/config/secrets/prod/prod.decrypt.private.php
/public/bundles/
/var/
/vendor/
###< symfony/framework-bundle ###

# Composer local cache used only during dependency installation.
/.composer-cache/
/.composer-home/

# Local logs and operating system files.
*.log
.DS_Store
Thumbs.db
Desktop.ini
###> lexik/jwt-authentication-bundle ###
/config/jwt/*.pem
###< lexik/jwt-authentication-bundle ###

# OpenSSL local random seed generated during JWT key creation.
/.rnd

###> phpunit/phpunit ###
/phpunit.xml
/.phpunit.cache/
###< phpunit/phpunit ###
/.env.test.local
/config/jwt/**/*.pem
